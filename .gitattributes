###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto eol=lf

# Explicitly declare Windows-only files to use CRLF
*.sln        text eol=crlf
*.slnx       text eol=crlf

# Scripts must always use LF - will break on Linux with CRLF
*.sh         text eol=lf
*.bash       text eol=lf
Makefile     text eol=lf
makefile     text eol=lf

# Docker
Dockerfile*  text eol=lf
*.dockerfile text eol=lf

# .NET
*.cs         text eol=lf
*.csproj     text eol=lf
*.fsproj     text eol=lf
*.props      text eol=lf
*.targets    text eol=lf

# Config / Data
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.xml        text eol=lf
*.env        text eol=lf
*.env.*      text eol=lf

# Binary files - no line ending conversion
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.zip  binary
*.pdf  binary
