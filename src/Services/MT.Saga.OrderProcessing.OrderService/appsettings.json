{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cache": {
    "Redis": {
      "Host": "localhost",
      "Port": 6379,
      "Password": "",
      "Secure": false,
      "InstanceName": "mt-saga-order-processing"
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/"
    },
    "Topology": {
      "EventsExchangeName": "orders.events-exchange",
      "EventsExchangeType": "topic"
    },
    "Resilience": {
      "PrefetchCount": 16,
      "MaxRetryAttempts": 5,
      "PublishMaxAttempts": 3,
      "PublishRetryDelayMilliseconds": 200,
      "ConcurrentMessageLimit": 8,
      "KillSwitchActivationThreshold": 10,
      "KillSwitchTripThreshold": 0.15,
      "KillSwitchRestartTimeout": "00:01:00"
    }
  },
  "Database": {
    "Postgres": {
      "Host": "localhost",
      "Port": 5432,
      "UserName": "postgres",
      "Password": "postgres",
      "Database": "mt_saga_order_processing",
      "MaintenanceDatabase": "postgres",
      "Schema": "public"
    },
    "Pool": {
      "ConnectionTimeout": 30,
      "CommandTimeout": 30,
      "MinPoolSize": 5,
      "MaxPoolSize": 100,
      "KeepAlive": 30,
      "Multiplexing": false
    }
  },
  "Networking": {
    "ForwardedHeaders": {
      "Enabled": false,
      "KnownProxies": [],
      "KnownNetworks": []
    }
  },
  "Swagger": {
    "Enabled": true,
    "RoutePrefix": "swagger",
    "DocumentTitle": "MT.Saga Order Service API"
  },
  "AllowedHosts": "*"
}
